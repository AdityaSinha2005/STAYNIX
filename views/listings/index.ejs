<% layout("layouts/boilerplate") %>

<style>
#filters{
display:flex;
flex-wrap:nowrap;
overflow-x:auto;
overflow-y:hidden;
gap:1.5rem;
padding-bottom:1rem;
margin-bottom:2rem;
scrollbar-width:none;
}

#filters::-webkit-scrollbar{
display:none;
}

.filter{
flex:0 0 auto;
text-align:center;
opacity:0.7;
min-width:80px;
transition:0.2s;
}

.card{
border:none !important;
transition:transform 0.3s ease;
overflow:hidden;
}

@media (min-width:769px){

.card:hover{
transform:translateY(-5px);
}
}
.card-img-overlay{
opacity:0;
}

.card-img-overlay:hover{
opacity:0.15;
background:white;
}

@media (max-width:576px){

.listing-img{
height:13rem;
}

.tax-toggle{
padding:0.5rem;
font-size:0.75rem;
}

.filter p{
font-size:0.7rem;
}

}

.filter:hover{
opacity:1;
cursor:pointer;
transform:translateY(-2px);
}

.filter p{
font-size:0.8rem;
margin:0;
white-space:nowrap;

}

.filter i{
font-size:1.3rem;
margin-bottom:0.4rem;
margin-top:0.8rem;
}

.tax-toggle{
flex:0 0 auto;
margin-left:auto;
border:1px solid #ddd;
padding:0.7rem 1rem;
border-radius:1rem;
margin-top:0.8rem;
white-space:nowrap;
}

.listing-img{
    width:100%;
    height:20rem;
    object-fit:cover;
    border-radius: 1rem 1rem 0 0;
}

.listing-link{
text-decoration:none;
color:black;
display:block;
width:100%;
}

@media (max-width:768px){

#filters{
gap:1rem;
}

.filter{
min-width:65px;
}

.filter i{
font-size:1rem;
}

.tax-toggle{
margin-left:0;
margin-right:1rem;
font-size:0.8rem;
}

.listing-img{
height:15rem;
}

.card-text{
font-size:0.9rem;
}

}
</style>

<div class="hero-content">
<div class="hero-section">

    <i class="fa-solid fa-plane plane-icon"></i>
    <i class="fa-solid fa-mountain mountain-icon"></i>
    <i class="fa-solid fa-compass compass-icon"></i>

    <div class="hero-content">
        <h1>Travel Smart with StayNix</h1>
        <p>Find amazing stays around the world</p>
    </div>

</div>
</div>

<div id="filters">

<div class="filter"
onclick="window.location='/listings?category=trending'">
<div><i class="fa-solid fa-fire"></i></div>
<p>Trending</p>
</div>

<div class="filter"
onclick="window.location='/listings?category=iconic-cities'">
<div><i class="fa-solid fa-mountain-city"></i></div>
<p>Iconic Cities</p>
</div>

<div class="filter"
onclick="window.location='/listings?category=mountains'">
<div><i class="fa-solid fa-mountain"></i></div>
<p>Mountains</p>
</div>

<div class="filter"
onclick="window.location='/listings?category=castles'">
<div><i class="fa-brands fa-fort-awesome"></i></div>
<p>Castles</p>
</div>

<div class="filter"
onclick="window.location='/listings?category=swimming'">
<div><i class="fa-solid fa-person-swimming"></i></div>
<p>Swimming Pools</p>
</div>

<div class="filter"
onclick="window.location='/listings?category=boats'">
<div><i class="fa-solid fa-ship"></i></div>
<p>Boats</p>
</div>

<div class="filter"
onclick="window.location='/listings?category=beach'">
<div><i class="fa-solid fa-umbrella-beach"></i></div>
<p>Beach</p>
</div>

<div class="filter"
onclick="window.location='/listings?category=wellness'">
<div><i class="fa-solid fa-spa"></i></div>
<p>Wellness</p>
</div>

<div class="filter"
onclick="window.location='/listings?category=hiking'">
<div><i class="fa-solid fa-person-hiking"></i></div>
<p>Hiking</p>
</div>

<div class="filter"
onclick="window.location='/listings?category=tents'">
<div><i class="fa-solid fa-tent"></i></div>
<p>Tents</p>
</div>

<div class="tax-toggle">

<div class="form-check-reverse form-switch">
<input
class="form-check-input"
type="checkbox"
role="switch"
id="flexswitchCheckDefault">
<label
class="form-check-label"
for="flexswitchCheckDefault">

Display total after taxes

</label>

</div>

</div>

</div>


<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mt-3">

<% if(allListings.length===0){ %>

<h3 class="text-center mt-5">
No listings found
</h3>

<% } %>

<% for(let listing of allListings){ %>

<div class="col mb-4">
<a href="/listings/<%= listing.id %>" class="listing-link">


<div class="card h-100" data-price="<%= listing.price %>">

<img src="<%= listing.image.url %>" class="card-img-top listing-img" alt="listing-image">

<div class="card-img-overlay"></div>

<div class="card-body">

<p class="card-text">
<b><%= listing.title %></b><br>

<span class="normal-price">
&#8377;<%= listing.price.toLocaleString("en-IN") %>/night
</span>

<span class="tax-price" style="display:none;">
&#8377;<%= (listing.price*1.18).toLocaleString("en-IN") %>/night (incl. taxes)
</span>

</p>

</div>

</div>

</a>

</div>

<% } %>

</div>



<script>

const taxToggle=document.getElementById("flexswitchCheckDefault");

taxToggle.addEventListener("change",()=>{

const cards=document.querySelectorAll(".card");

cards.forEach((card)=>{

const normalPrice=card.querySelector(".normal-price");
const taxPrice=card.querySelector(".tax-price");

if(taxToggle.checked){
normalPrice.style.display="none";
taxPrice.style.display="inline";
}
else{
normalPrice.style.display="inline";
taxPrice.style.display="none";
}

});

});

</script>