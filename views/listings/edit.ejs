<% layout("layouts/boilerplate") %>

<div class="row justify-content-center mt-4">
<div class="col-12 col-md-10 col-lg-8">

<h3 class="mb-4">Edit your Listing</h3>

<form method="POST" action="/listings/<%= listing.id %>?_method=PUT" enctype="multipart/form-data">

<div class="mb-3">
<label class="form-label">Title</label>
<input type="text" value="<%= listing.title %>" name="listing[title]" class="form-control" required>
</div>

<div class="mb-3">
<label class="form-label">Description</label>
<textarea name="listing[description]" class="form-control" rows="4" required><%= listing.description %></textarea>
</div>

<div class="row g-3">

<div class="mb-3 col-md-4">
<label class="form-label">Price</label>
<input type="number" value="<%= listing.price %>" name="listing[price]" class="form-control" required>
</div>

<div class="mb-3 col-md-8">
<label class="form-label">Country</label>
<input type="text" value="<%= listing.country %>" name="listing[country]" class="form-control" required>
</div>

</div>

<div class="mb-3">
<label class="form-label">Current Image</label>

<img 
src="<%= listing.image.url %>" 
alt="<%= listing.title %>" 
class="img-fluid rounded"
style="width:300px; max-width:350px; height:200px; object-fit:cover">

</div>

<div class="mb-3">
<label class="form-label">Upload New Image</label>
<input type="file"  name="listing[image]" class="form-control">
</div>

<div class="mb-3">

<label class="form-label">
Category
</label>

<select
name="listing[category]"
class="form-select"
required>

<option value="trending"
<%= listing.category==="trending" ? "selected" : "" %>>
Trending
</option>

<option value="iconic-cities"
<%= listing.category==="iconic-cities" ? "selected" : "" %>>
Iconic Cities
</option>

<option value="mountains"
<%= listing.category==="mountains" ? "selected" : "" %>>
Mountains
</option>

<option value="castles"
<%= listing.category==="castles" ? "selected" : "" %>>
Castles
</option>

<option value="swimming"
<%= listing.category==="swimming" ? "selected" : "" %>>
Swimming Pools
</option>

<option value="boats"
<%= listing.category==="boats" ? "selected" : "" %>>
Boats
</option>

<option value="beach"
<%= listing.category==="beach" ? "selected" : "" %>>
Beach
</option>

<option value="wellness"
<%= listing.category==="wellness" ? "selected" : "" %>>
Wellness
</option>

<option value="hiking"
<%= listing.category==="hiking" ? "selected" : "" %>>
Hiking
</option>

<option value="tents"
<%= listing.category==="tents" ? "selected" : "" %>>
Tents
</option>

</select>

</div>


<div class="mb-3">
<label class="form-label">Location</label>
<input type="text" value="<%= listing.location %>" name="listing[location]" class="form-control" required>
</div>



<div class="mt-4">

<button
type="submit"
class="btn btn-dark edit-btn w-100">

Update Listing

</button>

</div>


</form>

</div>
</div>